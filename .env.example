# Redis - Upstash free tier: https://upstash.com
# Local dev: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Local fallback (set 0 to force real Redis)
ALLOW_FAKE_REDIS=1

# Modal credentials - https://modal.com
# Generate with: modal token new
MODAL_TOKEN_ID=your_modal_token_id
MODAL_TOKEN_SECRET=your_modal_token_secret

# Set after deploying modal/vllm_server.py
MODAL_VLLM_URL=https://YOUR_ENDPOINT.modal.run

# Worker execution mode
# 0 = local worker only
# 1 = call deployed Modal worker first
USE_MODAL_REMOTE=0

# If remote call fails and this is 1, fallback to local worker
MODAL_LOCAL_FALLBACK=1

# Deployed Modal app/function names for worker calls
MODAL_WORKER_APP=pdf-pipeline-worker
MODAL_WORKER_FUNCTION=process_chunk_remote
